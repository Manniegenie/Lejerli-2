# ─────────────────────────────────────────────
#  Lejerli Technologies  —  Environment Config
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/lejerli
MONGODB_URI_PROD=mongodb+srv://<user>:<password>@cluster.mongodb.net/lejerli?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DISABLED=false
REDIS_KEY_PREFIX=lejerli:

# ── Auth ──────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
REFRESH_JWT_SECRET=another_very_long_random_refresh_secret
REFRESH_JWT_EXPIRES_IN=30d

# ── Reconciliation Engine ─────────────────────
RECON_TOLERANCE_USD=1.00
RECON_RUN_INTERVAL=*/15 * * * *
RECON_BATCH_SIZE=100

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW_MS=60000

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── OTC / Market Data ─────────────────────────
PRICE_FEED_URL=https://api.coingecko.com/api/v3
PRICE_FEED_API_KEY=

# ── WebSocket ─────────────────────────────────
WS_PATH=/ws
